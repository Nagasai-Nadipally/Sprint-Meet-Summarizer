# Copy this file to ".env" (next to docker-compose.yml) and fill in your values.
# docker-compose reads it automatically.

# =============================================================================
# AI PROVIDER  —  pick ONE of the two options below.
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION A — Groq  (FREE, no credit card required)  ◀── recommended to start
#   1. Sign up at https://console.groq.com  (email or Google login)
#   2. Open "API Keys" → "Create API Key" → copy it (starts with gsk_)
#   3. Paste it below and keep these three settings as-is.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=gsk_your-groq-key-here
OPENAI_BASE_URL=https://api.groq.com/openai
WHISPER_MODEL=whisper-large-v3
GPT_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# OPTION B — OpenAI  (paid; requires a payment method on your OpenAI account)
#   To use this instead, comment out Option A above and uncomment these:
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com
# WHISPER_MODEL=whisper-1
# GPT_MODEL=gpt-4o-mini


# =============================================================================
# SECURITY
# =============================================================================
# A Base64 secret that decodes to >= 256 bits. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMTIzNDU2Nzg5MA==


# =============================================================================
# EMAIL  (optional — leave blank to disable the "Email summary" feature)
# For Gmail, use an App Password, not your account password.
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@meetingnotes.local
